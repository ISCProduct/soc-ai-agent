# OCI デプロイ用 .env サンプル
# サーバー上で .env にコピーして使用する

# MySQL (Dockerコンテナ)
MYSQL_ROOT_PASSWORD=YourRootPassword1!
DB_USER=soc_user
DB_PASSWORD=YourDbPassword1!
DB_NAME=soc_db

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_HINTS_MODEL=gpt-4o-search-preview
OPENAI_HINTS_PARSE_MODEL=gpt-4o

# RAG / Company Graph ポート
RAG_REVIEW_PORT=9000
COMPANY_GRAPH_PORT=9100

# GBizINFO (任意)
GBIZINFO_API_KEY=
GBIZINFO_BASE_URL=
